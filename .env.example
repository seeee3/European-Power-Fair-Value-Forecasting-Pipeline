# Copy this file to .env and fill in your keys
# Never commit .env to version control

# OpenAI API key (required for LLM QA component)
OPENAI_API_KEY=sk-...

# ENTSO-E Transparency Platform API key (optional - falls back to SMARD if absent)
# Register at: https://transparency.entsoe.eu/usrm/user/createPublicUser
ENTSOE_API_KEY=

# Data configuration
MARKET=DE          # Bidding zone: DE, FR, NL, GB
START_DATE=2022-01-01
END_DATE=2025-12-31
